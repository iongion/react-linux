{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!**/*.svg", "!**/*.tsx", "!support/react-linux-gallery/gnome/stylesheet.css"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "off"
      },
      "performance": {
        "noDelete": "off"
      },
      "preset": "recommended",
      "style": {
        "noNonNullAssertion": "off",
        "useSelfClosingElements": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noDebugger": "off",
        "noDuplicateProperties": "off",
        "noExplicitAny": "off"
      }
    }
  },
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
