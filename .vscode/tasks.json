{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "prepare",
      "detail": "Install package dependencies with the pinned yarn lockfile.",
      "type": "shell",
      "command": "yarn install --frozen-lockfile",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "prepare: system deps",
      "detail": "Install GNOME Shell devkit and native UI visual-debug dependencies.",
      "type": "shell",
      "command": "make prepare-system",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "gnome: gallery",
      "detail": "Run the visible GNOME Shell devkit gallery loop.",
      "type": "shell",
      "command": "yarn gnome",
